# Copy to .env (in /opt/ganitel/ on the VPS) and fill in real values.

# --- Database (Supabase managed Postgres + PostGIS) ---
# Use the SESSION pooler (port 5432), not transaction (6543).
# Format: postgresql+asyncpg://postgres.<project_ref>:<password>@aws-<n>-<region>.pooler.supabase.com:5432/postgres
DATABASE_URL=

# --- App ---
ENVIRONMENT=production
DEBUG=false

CORS_ORIGINS=https://yourdomain.com

# Provider-neutral JWT verification. Fill with whichever auth provider's
# JWKS endpoint you wire (Supabase Auth, better-auth, Clerk, ...).
JWT_JWKS_URL=
JWT_ISSUER=

# --- SMS routing for OTP delivery ---
# African numbers (CC 20, 27, 21x-29x except 297/298/299) → Africa's Talking.
# Everything else → Twilio. Both are checked by the hook based on the recipient.

# Africa's Talking (sandbox by default; switch to live for production)
AT_USERNAME=sandbox
AT_API_KEY=
AT_SENDER_ID=
AT_BASE_URL=https://api.sandbox.africastalking.com

# Twilio — required for non-African numbers (or set both blank if Africa-only).
# Configure either TWILIO_FROM_NUMBER OR TWILIO_MESSAGING_SERVICE_SID.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
TWILIO_MESSAGING_SERVICE_SID=

# --- Supabase Auth Send SMS Hook secret (Standard Webhooks) ---
SUPABASE_AUTH_HOOK_SECRET=

# --- Storage (S3-compatible: AWS S3, Cloudflare R2, Supabase Storage, MinIO) ---
S3_ENDPOINT_URL=
S3_REGION=auto
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET=ganitel-uploads

# --- Payments ---
TRANZAK_APP_ID=
TRANZAK_APP_KEY=
TRANZAK_WEBHOOK_SECRET=
PAYMENT_RETURN_URL=https://yourdomain.com/payment/success

APP_BASE_URL=https://yourdomain.com

TEAM_REVIEW_SECRET=dev-only-change-me

RESEND_API_KEY=
RESEND_FROM_EMAIL=Ganitel <onboarding@resend.dev>
