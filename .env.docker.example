# Copy to .env and fill in real values before running docker compose

# --- Postgres (used by both the db service and DATABASE_URL construction) ---
POSTGRES_DB=ganitel_prod
POSTGRES_USER=ganitel
POSTGRES_PASSWORD=CHANGE_THIS

# --- App ---
ENVIRONMENT=production
DEBUG=false
SECRET_KEY=CHANGE_THIS_64_CHAR_HEX
WORKERS=2

CORS_ORIGINS=https://yourdomain.com

BETTER_AUTH_JWKS_URL=
BETTER_AUTH_ISSUER=

# --- Storage (Cloudflare R2 or leave STORAGE_TYPE=local for VPS disk) ---
STORAGE_TYPE=local
S3_ENDPOINT_URL=
S3_REGION=auto
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET=ganitel-uploads
S3_PUBLIC_URL_BASE=

# --- Payments ---
TRANZAK_APP_ID=
TRANZAK_APP_KEY=
TRANZAK_WEBHOOK_SECRET=
PAYMENT_RETURN_URL=https://yourdomain.com/payment/success

# --- OAuth ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
