api.ganitel.com {
	encode zstd gzip

	log {
		output stdout
		format json
	}

	reverse_proxy api:8000 {
		transport http {
			dial_timeout 5s
			response_header_timeout 15s
			read_timeout 30s
			write_timeout 30s
		}
	}
}

:80 {
	@ours host api.ganitel.com
	handle @ours {
		redir https://{host}{uri} 308
	}
	handle {
		abort
	}
}
