# API
# In dev, /api/* (except /api/auth/*) goes through Vite's proxy → http://localhost:8000.
# For prod, point INTERNAL_API_URL at your backend (server-side fetch).
VITE_API_BASE_URL=/api
INTERNAL_API_URL=http://localhost:8000/api

# better-auth
# The public URL of this app — used as baseURL and JWT issuer.
BETTER_AUTH_URL=http://localhost:3000
# Postgres connection string (same DB as the backend).
DATABASE_URL=postgresql://ganitel:ganitel@localhost:5432/ganitel
# Secret for cookie signing. Generate with: openssl rand -hex 32
BETTER_AUTH_SECRET=

# Google OAuth — Authorized redirect URI: <BETTER_AUTH_URL>/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Prelude — phone OTP (https://prelude.so)
# Get your API key from the Prelude dashboard → All Services → Configure → Keys
PRELUDE_API_KEY=

# Demo bypass — set to a phone number to skip OTP for that number (dev only, never set in prod)
DEMO_PHONE_NUMBER=

# Maps (Google Maps)
VITE_GOOGLE_MAPS_KEY=your_google_maps_key_here
