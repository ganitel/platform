# API
# In dev, /api/* requests are proxied to the FastAPI backend (vite.config.ts).
# For prod, point INTERNAL_API_URL at the backend's private hostname.
VITE_API_BASE_URL=/api
INTERNAL_API_URL=http://localhost:8000/api

# Supabase (Auth + Postgres + Storage)
# Find these in Supabase dashboard → Project Settings → API.
VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# Prelaunch mode — hides bookings/profile, shows waitlist form on listings instead of booking
VITE_PRELAUNCH_MODE=false
