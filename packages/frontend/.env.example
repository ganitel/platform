# API
# Browser fetches use a relative `/api` path:
#   - dev: Vite proxies `/api/*` to the FastAPI backend (vite.config.ts)
#   - prod: Vercel rewrites `/api/*` to api.ganitel.com (vercel.json)
# SSR loaders run server-side and need an absolute URL — set API_BASE_URL.
API_BASE_URL=http://localhost:8000/api

# Supabase (Auth + Postgres + Storage)
# Find these in Supabase dashboard → Project Settings → API.
VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# Prelaunch mode — hides bookings/profile, shows waitlist form on listings instead of booking
VITE_PRELAUNCH_MODE=false

# Checkout provider — defaults to noop in local/test builds and tranzak in production builds.
VITE_PAYMENT_PROVIDER=noop
