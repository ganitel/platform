# API
# Relative path → goes through the Vite proxy in dev (vite.config.ts → http://localhost:8000).
# For production, set this to your full API URL (e.g. https://api.example.com/api).
VITE_API_BASE_URL=/api

# Auth (Clerk) — required at app boot.
# Get from https://dashboard.clerk.com → API Keys.
VITE_CLERK_PUBLISHABLE_KEY=pk_test_your_key_here

# Maps (Google Maps)
VITE_GOOGLE_MAPS_KEY=your_google_maps_key_here
