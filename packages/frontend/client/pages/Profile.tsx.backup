import { useMemo } from "react";
import { Link, useNavigate } from "react-router-dom";
import { Header } from "@/components/Header";
import { Footer } from "@/components/Footer";
import { useAuth } from "@/hooks/useAuth";
import { useProfile } from "@/hooks/useProfile";
import { Avatar, AvatarFallback, AvatarImage } from "@/components/ui/avatar";
import { Button } from "@/components/ui/button";
import {
  Card,
  CardContent,
  CardHeader,
  CardTitle,
} from "@/components/ui/card";
import { Loader2, ArrowLeft, Mail, Phone, Calendar, Heart, CreditCard, Building, HelpCircle, Bell, Globe, Gift } from "lucide-react";

export default function Profile() {
  const navigate = useNavigate();
  const { signOut } = useAuth();
  const { data: profile, isLoading, isError } = useProfile();

  const fullName = useMemo(() => {
    const name = [profile?.first_name, profile?.last_name]
      .filter(Boolean)
      .join(" ");
    return name || profile?.email || "Utilisateur";
  }, [profile]);

  const handleSignOut = async () => {
    try {
      await signOut();
      navigate("/");
    } catch (err: any) {
      console.error("Erreur lors de la déconnexion:", err);
    }
  };

  if (isLoading) {
    return (
      <div className="min-h-screen bg-ganitel-background-primary flex flex-col">
        <Header />
        <main className="flex-1 flex items-center justify-center">
          <div className="flex flex-col items-center gap-2">
            <Loader2 className="h-12 w-12 animate-spin text-primary" />
            <p className="text-sm text-ganitel-text-label">Chargement du profil…</p>
          </div>
        </main>
        <Footer />
      </div>
    );
  }

  if (isError || !profile) {
    return (
      <div className="min-h-screen bg-ganitel-background-primary flex flex-col">
        <Header />
        <main className="flex-1 container mx-auto px-4 py-8">
          <Card className="max-w-xl mx-auto">
            <CardHeader>
              <CardTitle>Impossible de charger votre profil</CardTitle>
            </CardHeader>
            <CardContent className="grid gap-4">
              <Button variant="outline" onClick={() => window.location.reload()}>
                Réessayer
              </Button>
              <Button variant="secondary" onClick={() => navigate("/")}>Retour à l'accueil</Button>
            </CardContent>
          </Card>
        </main>
        <Footer />
      </div>
    );
  }

  return (
    <div className="min-h-screen bg-ganitel-background-primary flex flex-col">
      <Header />
      <main className="flex-1 container mx-auto px-4 py-8">
        {/* Header with back button and title */}
        <div className="flex items-center gap-4 mb-8">
          <Button
            variant="ghost"
            size="sm"
            onClick={() => navigate(-1)}
            className="flex items-center gap-2"
          >
            <ArrowLeft className="h-4 w-4" />
            Retour
          </Button>
          <h1 className="text-2xl font-bold text-ganitel-text-title">My Profil</h1>
        </div>

        {/* Avatar and basic info */}
        <div className="grid gap-6 lg:grid-cols-[300px_1fr]">
          <div className="space-y-6">
            {/* Avatar */}
            <Card>
              <CardContent className="pt-6">
                <div className="flex flex-col items-center gap-4">
                  <Avatar className="h-24 w-24">
                    {profile.profile_picture ? (
                      <AvatarImage src={profile.profile_picture} alt={fullName} />
                    ) : (
                      <AvatarFallback className="text-lg">
                        {fullName.slice(0, 1).toUpperCase()}
                      </AvatarFallback>
                    )}
                  </Avatar>
                  <div className="text-center">
                    <h2 className="text-xl font-bold text-ganitel-text-title">{fullName}</h2>
                    <p className="text-sm text-ganitel-text-label flex items-center justify-center gap-1 mt-1">
                      <Mail className="h-4 w-4" />
                      {profile.email}
                    </p>
                    {profile.phone && (
                      <p className="text-sm text-ganitel-text-label flex items-center justify-center gap-1 mt-1">
                        <Phone className="h-4 w-4" />
                        {profile.phone}
                      </p>
                    )}
                  </div>
                </div>
              </CardContent>
            </Card>
          </div>

          <div className="space-y-6">
            {/* Navigation bar */}
            <Card>
              <CardContent className="pt-6">
                <div className="grid grid-cols-2 md:grid-cols-4 gap-4">
                  <Button
                    variant="outline"
                    className="flex flex-col items-center gap-2 h-auto py-4"
                    onClick={() => navigate("/my-bookings")}
                  >
                    <Calendar className="h-6 w-6" />
                    <span className="text-sm">Booking</span>
                  </Button>
                  <Button
                    variant="outline"
                    className="flex flex-col items-center gap-2 h-auto py-4"
                    onClick={() => navigate("/my-properties")}
                  >
                    <Building className="h-6 w-6" />
                    <span className="text-sm">Collection</span>
                  </Button>
                  <Button
                    variant="outline"
                    className="flex flex-col items-center gap-2 h-auto py-4"
                    onClick={() => navigate("/my-wishlist")}
                  >
                    <Heart className="h-6 w-6" />
                    <span className="text-sm">Favorites</span>
                  </Button>
                  <Button
                    variant="outline"
                    className="flex flex-col items-center gap-2 h-auto py-4"
                    onClick={() => navigate("/payments")}
                  >
                    <CreditCard className="h-6 w-6" />
                    <span className="text-sm">Payments</span>
                  </Button>
                </div>
              </CardContent>
            </Card>

            {/* ACCOUNT Section */}
            <Card>
              <CardHeader>
                <CardTitle className="text-lg">ACCOUNT</CardTitle>
              </CardHeader>
              <CardContent className="space-y-4">
                <Button
                  variant="ghost"
                  className="w-full justify-start"
                  onClick={() => navigate("/profile/personal-information")}
                >
                  Personal information
                </Button>
                <Button
                  variant="ghost"
                  className="w-full justify-start"
                  onClick={() => navigate("/my-properties")}
                >
                  Property
                </Button>
              </CardContent>
            </Card>

            {/* HELP AND INFORMATION Section */}
            <Card>
              <CardHeader>
                <CardTitle className="text-lg">HELP AND INFORMATION</CardTitle>
              </CardHeader>
              <CardContent className="space-y-4">
                <Button
                  variant="ghost"
                  className="w-full justify-start"
                  onClick={() => navigate("/about")}
                >
                  <HelpCircle className="h-4 w-4 mr-2" />
                  About us
                </Button>
                <Button
                  variant="ghost"
                  className="w-full justify-start"
                  onClick={() => navigate("/help")}
                >
                  <HelpCircle className="h-4 w-4 mr-2" />
                  Help Center
                </Button>
              </CardContent>
            </Card>

            {/* TO DISCOVER Section */}
            <Card>
              <CardHeader>
                <CardTitle className="text-lg">TO DISCOVER</CardTitle>
              </CardHeader>
              <CardContent className="space-y-4">
                <Button
                  variant="ghost"
                  className="w-full justify-start"
                  onClick={() => navigate("/offers")}
                >
                  <Gift className="h-4 w-4 mr-2" />
                  Offers
                </Button>
              </CardContent>
            </Card>

            {/* PREFERENCES Section */}
            <Card>
              <CardHeader>
                <CardTitle className="text-lg">PREFERENCES</CardTitle>
              </CardHeader>
              <CardContent className="space-y-4">
                <Button
                  variant="ghost"
                  className="w-full justify-start"
                  onClick={() => navigate("/profile/notifications")}
                >
                  <Bell className="h-4 w-4 mr-2" />
                  Notification
                </Button>
                <Button
                  variant="ghost"
                  className="w-full justify-start"
                  onClick={() => navigate("/profile/language")}
                >
                  <Globe className="h-4 w-4 mr-2" />
                  Language
                </Button>
              </CardContent>
            </Card>

            {/* Sign out button */}
            <Card>
              <CardContent className="pt-6">
                <Button
                  variant="destructive"
                  className="w-full"
                  onClick={handleSignOut}
                >
                  Déconnexion
                </Button>
              </CardContent>
            </Card>
          </div>
        </div>
      </main>
      <Footer />
    </div>
  );
}
      city: profile.city ?? "",
    });
  }, [profile]);

  const fullName = useMemo(() => {
    const name = [profile?.first_name, profile?.last_name]
      .filter(Boolean)
      .join(" ");
    return name || profile?.email || "Utilisateur";
  }, [profile]);

  const handleSignOut = async () => {
    try {
      await signOut();
      navigate("/");
    } catch (err: any) {
      toast({
        title: "Erreur",
        description: err?.message || "Impossible de se déconnecter.",
        variant: "destructive",
      });
    }
  };

  const handleSave = async () => {
    if (!profile) return;

    try {
      await updateProfile.mutateAsync({
        first_name: form.first_name,
        last_name: form.last_name,
        phone: form.phone,
        bio: form.bio,
        country: form.country,
        city: form.city,
      });

      toast({
        title: "Profil mis à jour",
        description: "Vos informations ont été enregistrées.",
      });
      setIsEditing(false);
    } catch (err: any) {
      toast({
        title: "Erreur",
        description: err?.message || "Impossible de mettre à jour le profil.",
        variant: "destructive",
      });
    }
  };

  const handleAvatarChange = async (file?: File) => {
    if (!file) return;
    try {
      await uploadAvatar.mutateAsync(file);
      toast({
        title: "Photo de profil mise à jour",
      });
      // Refresh profile data
      refetch();
    } catch (err: any) {
      toast({
        title: "Erreur",
        description: err?.message || "Impossible de télécharger la photo.",
        variant: "destructive",
      });
    }
  };

  const handleFileSelect = (event: React.ChangeEvent<HTMLInputElement>) => {
    const file = event.target.files?.[0];
    if (!file) return;
    handleAvatarChange(file);
  };

  if (isLoading) {
    return (
      <div className="min-h-screen bg-ganitel-background-primary flex flex-col">
        <Header />
        <main className="flex-1 flex items-center justify-center">
          <div className="flex flex-col items-center gap-2">
            <Loader2 className="h-12 w-12 animate-spin text-primary" />
            <p className="text-sm text-ganitel-text-label">Chargement du profil…</p>
          </div>
        </main>
        <Footer />
      </div>
    );
  }

  if (isError || !profile) {
    return (
      <div className="min-h-screen bg-ganitel-background-primary flex flex-col">
        <Header />
        <main className="flex-1 flex items-center justify-center">
          <Card className="max-w-xl w-full">
            <CardHeader>
              <CardTitle>Impossible de charger votre profil</CardTitle>
              <CardDescription>Veuillez réessayer plus tard.</CardDescription>
            </CardHeader>
            <CardContent className="grid gap-4">
              <Button variant="outline" onClick={() => refetch()}>
                Réessayer
              </Button>
              <Button variant="secondary" onClick={() => navigate("/")}>Retour à l'accueil</Button>
            </CardContent>
          </Card>
        </main>
        <Footer />
      </div>
    );
  }

  return (
    <div className="min-h-screen bg-ganitel-background-primary flex flex-col">
      <Header />
      <main className="flex-1 container mx-auto px-4 py-8">
        <div className="grid gap-6 lg:grid-cols-[1.2fr_0.8fr]">
          <section className="space-y-6">
            <Card>
              <CardHeader className="flex flex-col gap-4 md:flex-row md:items-center md:justify-between">
                <div className="flex items-center gap-4">
                  <Avatar className="h-16 w-16">
                    {profile.profile_picture ? (
                      <AvatarImage src={profile.profile_picture} alt={fullName} />
                    ) : (
                      <AvatarFallback>{fullName.slice(0, 1).toUpperCase()}</AvatarFallback>
                    )}
                  </Avatar>
                  <div>
                    <CardTitle className="text-lg">{fullName}</CardTitle>
                    <p className="text-sm text-ganitel-text-label">{profile.email}</p>
                  </div>
                </div>

                <div className="flex items-center gap-2">
                  <Button
                    variant="secondary"
                    size="sm"
                    onClick={() => {
                      setIsEditing(!isEditing);
                    }}
                    disabled={updateProfile.isPending}
                  >
                    {isEditing ? "Annuler" : "Modifier le profil"}
                  </Button>
                  <Button variant="outline" size="sm" onClick={handleSignOut}>
                    <LogOut className="mr-2 h-4 w-4" />
                    Déconnexion
                  </Button>
                </div>
              </CardHeader>

              <CardContent className="grid gap-4">
                <div className="flex flex-col gap-2">
                  <div className="flex items-center gap-2 text-sm text-ganitel-text-label">
                    <Mail className="h-4 w-4" />
                    {profile.email}
                  </div>
                  <div className="flex items-center gap-2 text-sm text-ganitel-text-label">
                    <Phone className="h-4 w-4" />
                    {profile.phone ?? "Pas de téléphone"}
                  </div>
                </div>

                <div className="grid grid-cols-1 gap-2 sm:grid-cols-2">
                  <div className="flex items-center gap-2 text-sm text-ganitel-text-label">
                    <MapPin className="h-4 w-4" />
                    {profile.city ?? "Ville non renseignée"}, {profile.country ?? "Pays non renseigné"}
                  </div>
                  <div className="flex items-center gap-2 text-sm text-ganitel-text-label">
                    <Globe className="h-4 w-4" />
                    {profile.language?.toUpperCase() ?? "--"}
                  </div>
                  <div className="flex items-center gap-2 text-sm text-ganitel-text-label">
                    <DollarSign className="h-4 w-4" />
                    {profile.currency ?? "--"}
                  </div>
                </div>

                {isEditing ? (
                  <div className="space-y-4">
                    <div className="grid gap-4 md:grid-cols-2">
                      <div>
                        <Label htmlFor="first_name">Prénom</Label>
                        <Input
                          id="first_name"
                          value={form.first_name}
                          onChange={(e) => setForm((prev) => ({ ...prev, first_name: e.target.value }))}
                        />
                      </div>
                      <div>
                        <Label htmlFor="last_name">Nom</Label>
                        <Input
                          id="last_name"
                          value={form.last_name}
                          onChange={(e) => setForm((prev) => ({ ...prev, last_name: e.target.value }))}
                        />
                      </div>
                    </div>

                    <div className="grid gap-4 md:grid-cols-2">
                      <div>
                        <Label htmlFor="phone">Téléphone</Label>
                        <Input
                          id="phone"
                          value={form.phone}
                          onChange={(e) => setForm((prev) => ({ ...prev, phone: e.target.value }))}
                        />
                      </div>
                      <div>
                        <Label htmlFor="country">Pays</Label>
                        <Input
                          id="country"
                          value={form.country}
                          onChange={(e) => setForm((prev) => ({ ...prev, country: e.target.value }))}
                        />
                      </div>
                    </div>

                    <div className="grid gap-4 md:grid-cols-2">
                      <div>
                        <Label htmlFor="city">Ville</Label>
                        <Input
                          id="city"
                          value={form.city}
                          onChange={(e) => setForm((prev) => ({ ...prev, city: e.target.value }))}
                        />
                      </div>
                      <div>
                        <Label htmlFor="bio">Bio</Label>
                        <Textarea
                          id="bio"
                          value={form.bio}
                          onChange={(e) => setForm((prev) => ({ ...prev, bio: e.target.value }))}
                          className="h-24"
                        />
                      </div>
                    </div>

                    <div className="flex flex-col gap-2 sm:flex-row sm:items-center sm:justify-between">
                      <div className="flex items-center gap-2">
                        <label
                          htmlFor="avatar-upload"
                          className="inline-flex cursor-pointer items-center gap-2 rounded-md border border-ganitel-stroke bg-white px-3 py-2 text-sm font-medium text-ganitel-text-title shadow-sm transition hover:bg-ganitel-background-secondary"
                        >
                          <Camera className="h-4 w-4" />
                          Changer la photo
                        </label>
                        <input
                          id="avatar-upload"
                          ref={fileInputRef}
                          type="file"
                          accept="image/*"
                          className="hidden"
                          onChange={handleFileSelect}
                        />
                        {uploadAvatar.isPending && (
                          <span className="text-sm text-ganitel-text-label">Téléchargement...</span>
                        )}
                      </div>
                      <div className="flex gap-2">
                        <Button
                          variant="secondary"
                          onClick={handleSave}
                          disabled={updateProfile.isPending}
                        >
                          {updateProfile.isPending ? (
                            <Loader2 className="mr-2 h-4 w-4 animate-spin" />
                          ) : (
                            <Edit2 className="mr-2 h-4 w-4" />
                          )}
                          Enregistrer
                        </Button>
                      </div>
                    </div>
                  </div>
                ) : (
                  <div className="space-y-3">
                    <div className="flex flex-col gap-1">
                      <h3 className="text-sm font-medium text-ganitel-text-title">À propos</h3>
                      <p className="text-sm text-ganitel-text-label">
                        {profile.bio ?? "Aucune description fournie."}
                      </p>
                    </div>
                    <div className="grid gap-2 sm:grid-cols-2">
                      <div className="rounded-lg border border-ganitel-stroke p-4">
                        <h4 className="text-xs font-medium uppercase text-ganitel-text-label">Préférences</h4>
                        <ul className="mt-2 space-y-2 text-sm text-ganitel-text-label">
                          <li className="flex items-center gap-2">
                            <Globe className="h-4 w-4" /> Langue: {profile.language?.toUpperCase() ?? "--"}
                          </li>
                          <li className="flex items-center gap-2">
                            <DollarSign className="h-4 w-4" /> Devise: {profile.currency ?? "--"}
                          </li>
                          <li className="flex items-center gap-2">
                            <span className="h-4 w-4 rounded-full bg-ganitel-primary" /> Notifications activées
                          </li>
                        </ul>
                      </div>
                      <div className="rounded-lg border border-ganitel-stroke p-4">
                        <h4 className="text-xs font-medium uppercase text-ganitel-text-label">Support</h4>
                        <ul className="mt-2 space-y-2 text-sm">
                          <li>
                            <Link
                              to="/support"
                              className="text-ganitel-primary hover:underline"
                            >
                              Contacter l&apos;assistance
                            </Link>
                          </li>
                          <li>
                            <Link
                              to="/policies"
                              className="text-ganitel-primary hover:underline"
                            >
                              Politique de confidentialité & CGU
                            </Link>
                          </li>
                        </ul>
                      </div>
                    </div>

                    <div className="mt-4">
                      <Button variant="outline" onClick={() => navigate("/my-bookings")}>Mes réservations</Button>
                    </div>
                  </div>
                )}
              </CardContent>
            </Card>
          </section>

          <section className="space-y-6">
            <Card>
              <CardHeader>
                <CardTitle>Actions</CardTitle>
                <CardDescription>Gérer votre compte et vos préférences.</CardDescription>
              </CardHeader>
              <CardContent className="space-y-3">
                <Button variant="outline" className="w-full" onClick={() => navigate("/my-bookings")}>Voir mes réservations</Button>
                <Button variant="outline" className="w-full" onClick={() => navigate("/my-wishlist")}>Ma liste de souhaits</Button>
                <Button variant="ghost" className="w-full" onClick={handleSignOut}>Déconnexion</Button>
              </CardContent>
            </Card>
          </section>
        </div>
      </main>
      <Footer />
    </div>
  );
}
