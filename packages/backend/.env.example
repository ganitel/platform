ENVIRONMENT=development
DEBUG=true

# Local Postgres (with PostGIS) on standard port.
DATABASE_URL=postgresql+asyncpg://ganitel:ganitel@localhost:5432/ganitel

CORS_ORIGINS=http://localhost:3000

# Clerk
CLERK_JWKS_URL=
CLERK_ISSUER=

# Object storage (S3-compatible).
#
# Supabase Storage (recommended for staging/prod): Dashboard → Storage → S3 — enable, then:
#   S3_ENDPOINT_URL=https://<project-ref>.storage.supabase.co/storage/v1/s3
#   S3_REGION=<region shown in dashboard>
#   S3_ACCESS_KEY_ID / S3_SECRET_ACCESS_KEY = generated S3 protocol keys
#   S3_BUCKET=<bucket id>
#   S3_PUBLIC_URL_BASE=https://<project-ref>.supabase.co/storage/v1/object/public/<bucket>
#
# Optional locally — `make seed` already uses externally-hosted demo photos
# via the URL passthrough in `app/core/storage.public_or_signed_url`, so you
# don't need a local object store to browse the seeded UI.
S3_ENDPOINT_URL=
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET=ganitel-uploads
S3_PUBLIC_URL_BASE=
