ENVIRONMENT=development
DEBUG=true

DATABASE_URL=postgresql+asyncpg://ganitel:ganitel@localhost:15432/ganitel
REDIS_URL=redis://localhost:6390/0

CORS_ORIGINS=http://localhost:3000
DEFAULT_CURRENCY=XAF

# Clerk
CLERK_JWKS_URL=
CLERK_ISSUER=

# Object storage (S3-compatible). Local = MinIO; prod = Supabase Storage S3 API.
#
# Supabase: Dashboard → Storage → S3 — enable S3, then:
#   S3_ENDPOINT_URL=https://<project-ref>.storage.supabase.co/storage/v1/s3
#   S3_REGION=<region from that page>
#   S3_ACCESS_KEY_ID / S3_SECRET_ACCESS_KEY = generated S3 protocol keys
#   S3_BUCKET=<bucket id>
# Public bucket reads (optional): S3_PUBLIC_URL_BASE=https://<ref>.supabase.co/storage/v1/object/public/<bucket>
#
# MinIO (local):
S3_ENDPOINT_URL=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_BUCKET=ganitel-uploads
S3_PUBLIC_URL_BASE=http://localhost:9000/ganitel-uploads
