# =========================================
# GANITEL BACKEND - APP SETTINGS TEMPLATE
# =========================================
# Source of truth: app/config.py
# Note: ENVIRONMENT=local is supported and mapped to development policy.

# Environment
ENVIRONMENT=local
TESTING=false
DEBUG=true

# Application
APP_NAME=Ganitel API
APP_VERSION=2.0.0

# Host port bindings (change if ports are already allocated)
APP_HOST_PORT=8000
POSTGRES_HOST_PORT=5432
TEST_POSTGRES_HOST_PORT=5433
REDIS_HOST_PORT=6379
PGADMIN_HOST_PORT=5050

# Security
SECRET_KEY=dev-secret-key-change-in-production
ALGORITHM=HS256
ENV_WORKERS=2
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# Database
POSTGRES_SERVER=localhost
POSTGRES_PORT=5432
POSTGRES_DB=ganitel_db
POSTGRES_USER=ganitel_user
POSTGRES_PASSWORD=ganitel_password
DATABASE_URL=
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=30

# Redis
REDIS_URL=redis://localhost:6379/0

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:8000
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_ALLOW_HEADERS=*

# Tranzak
TRANZAK_API_KEY=your-tranzak-api-key
TRANZAK_APP_ID=your-tranzak-app-id
TRANZAK_APP_KEY=your-tranzak-app-key
TRANZAK_BASE_URL=https://dsapi.tranzak.me/xp021/v1
TRANZAK_AUTH_BASE_URL=https://dsapi.tranzak.me
TRANZAK_WEBHOOK_SECRET=your-webhook-secret
TRANZAK_WEBHOOK_AUTH_KEY=your-tranzak-webhook-auth-key
TRANZAK_WEBHOOK_ID=

# Payment URLs
PAYMENT_CALLBACK_URL=http://localhost:8000/api/v1/payments/webhook/tranzak
PAYMENT_RETURN_URL=http://localhost:3000/payment/success

# Admin bootstrap account
ADMIN_EMAIL=admin@ganitel.com
ADMIN_PASSWORD=Change_This_Password_123!
ADMIN_FIRST_NAME=Admin
ADMIN_LAST_NAME=Ganitel

# Manual admin creation defaults (used by make *-admin-create)
ADMIN_CREATE_EMAIL=admin@ganitel.com
ADMIN_CREATE_FIRST_NAME=Admin
ADMIN_CREATE_LAST_NAME=Ganitel
ADMIN_CREATE_PHONE=+237600000000
ADMIN_CREATE_PASSWORD=Change_This_Password_123!

# OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/oauth/google/callback
FACEBOOK_APP_ID=your-facebook-app-id
FACEBOOK_APP_SECRET=your-facebook-app-secret
FACEBOOK_REDIRECT_URI=http://localhost:8000/api/v1/auth/oauth/facebook/callback
FRONTEND_URL=http://localhost:3000

# Orange Money
ORANGE_MONEY_CLIENT_ID=your-orange-money-client-id
ORANGE_MONEY_CLIENT_SECRET=your-orange-money-client-secret
ORANGE_MONEY_MERCHANT_KEY=your-orange-money-merchant-key
ORANGE_MONEY_TOKEN_URL=https://api.orange.com/oauth/v2/token
ORANGE_MONEY_PAYMENT_URL=https://api.orange.com/orange-money-webpay/cm/v1/webpayment
ORANGE_MONEY_WEBHOOK_URL=http://localhost:8000/api/v1/payments/webhook/orange

# MTN Mobile Money
MOBILE_MONEY_BASIC_AUTH=your-mobile-money-basic-auth
MOBILE_MONEY_TOKEN_URL=https://sandbox.momodeveloper.mtn.com/collection/token/
MOBILE_MONEY_PAYMENT_URL=https://sandbox.momodeveloper.mtn.com/collection/v1_0/requesttopay
MOBILE_MONEY_ENVIRONMENT=sandbox
MOBILE_MONEY_WEBHOOK_URL=http://localhost:8000/api/v1/payments/webhook/mobile-money

# File upload
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE=10485760

# Storage (Cloudflare R2)
STORAGE_TYPE=local
R2_BUCKET_NAME=ganitel-uploads
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_PUBLIC_URL=https://cdn.ganitel.com
R2_ENDPOINT_URL=
