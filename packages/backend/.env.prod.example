# =========================================
# GANITEL BACKEND - PRODUCTION SETTINGS TEMPLATE
# =========================================
# Source of truth: app/config.py

# Environment
ENVIRONMENT=production
TESTING=false
DEBUG=false

# Application
APP_NAME=Ganitel API
APP_VERSION=2.0.0
APP_HOST_PORT=8000
POSTGRES_HOST_PORT=5432
REDIS_HOST_PORT=6379

# Security (must be real values)
SECRET_KEY=CHANGE_THIS_TO_RANDOM_64_CHAR_HEX_STRING
ALGORITHM=HS256
ENV_WORKERS=3
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Database
POSTGRES_DB=ganitel_prod_db
POSTGRES_USER=ganitel_user
POSTGRES_PASSWORD=CHANGE_THIS_TO_STRONG_PASSWORD_MIN_20_CHARS

# Redis
REDIS_PASSWORD=CHANGE_THIS_TO_STRONG_REDIS_PASSWORD_MIN_20_CHARS
REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379/0

# CORS
CORS_ORIGINS=https://app.ganitel.com,https://www.app.ganitel.com
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_ALLOW_HEADERS=Authorization,Content-Type,Accept,Origin

# Tranzak
TRANZAK_API_KEY=CHANGE_THIS
TRANZAK_APP_ID=CHANGE_THIS
TRANZAK_APP_KEY=CHANGE_THIS
TRANZAK_BASE_URL=https://dsapi.tranzak.me/xp021/v1
TRANZAK_AUTH_BASE_URL=https://dsapi.tranzak.me
TRANZAK_WEBHOOK_SECRET=CHANGE_THIS
TRANZAK_WEBHOOK_AUTH_KEY=CHANGE_THIS
TRANZAK_WEBHOOK_ID=CHANGE_THIS

# Payment URLs
PAYMENT_CALLBACK_URL=https://app.ganitel.com/api/v1/payments/webhook/tranzak
PAYMENT_RETURN_URL=https://app.ganitel.com/payment/success

# Admin bootstrap account
ADMIN_EMAIL=admin@ganitel.com
ADMIN_PASSWORD=CHANGE_THIS_TO_STRONG_ADMIN_PASSWORD
ADMIN_FIRST_NAME=Admin
ADMIN_LAST_NAME=Ganitel

# OAuth
GOOGLE_CLIENT_ID=CHANGE_THIS
GOOGLE_CLIENT_SECRET=CHANGE_THIS
GOOGLE_REDIRECT_URI=https://app.ganitel.com/api/v1/auth/oauth/google/callback
FACEBOOK_APP_ID=CHANGE_THIS
FACEBOOK_APP_SECRET=CHANGE_THIS
FACEBOOK_REDIRECT_URI=https://app.ganitel.com/api/v1/auth/oauth/facebook/callback
FRONTEND_URL=https://app.ganitel.com

# Orange Money
ORANGE_MONEY_CLIENT_ID=CHANGE_THIS
ORANGE_MONEY_CLIENT_SECRET=CHANGE_THIS
ORANGE_MONEY_MERCHANT_KEY=CHANGE_THIS
ORANGE_MONEY_TOKEN_URL=https://api.orange.com/oauth/v2/token
ORANGE_MONEY_PAYMENT_URL=https://api.orange.com/orange-money-webpay/cm/v1/webpayment
ORANGE_MONEY_WEBHOOK_URL=https://app.ganitel.com/api/v1/payments/webhook/orange

# MTN Mobile Money
MOBILE_MONEY_BASIC_AUTH=CHANGE_THIS
MOBILE_MONEY_TOKEN_URL=https://sandbox.momodeveloper.mtn.com/collection/token/
MOBILE_MONEY_PAYMENT_URL=https://sandbox.momodeveloper.mtn.com/collection/v1_0/requesttopay
MOBILE_MONEY_ENVIRONMENT=sandbox
MOBILE_MONEY_WEBHOOK_URL=https://app.ganitel.com/api/v1/payments/webhook/mobile-money

# File upload
UPLOAD_DIR=/app/uploads
MAX_UPLOAD_SIZE=10485760

# Storage (Cloudflare R2)
STORAGE_TYPE=local
R2_BUCKET_NAME=ganitel-uploads
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_PUBLIC_URL=https://cdn.ganitel.com
R2_ENDPOINT_URL=

# Logging
LOG_LEVEL=INFO
